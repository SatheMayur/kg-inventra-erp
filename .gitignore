public/uploads/items/*
!public/uploads/items/.gitkeep

# SQLite database (do not commit data)
prisma/dev.db
prisma/dev.db.*
prisma/*.db-journal

# Recovered parent-repo backup (un-mix artifact)
.git_combined_backup/

# Skills directory
/skills/
