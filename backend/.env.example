# Database — individual vars (used by seed.js and tooling)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=fg_inventory
DB_USER=postgres
DB_PASSWORD=changeme

# Database — connection string (used by knex/app; overrides individual vars above if set)
DATABASE_URL=postgresql://postgres:changeme@localhost:5432/fg_inventory

# Auth
JWT_SECRET=change-this-to-a-random-256-bit-secret
JWT_EXPIRES_IN=8h

# Server
PORT=4000
NODE_ENV=production

# Optional: CORS origins (comma-separated)
CORS_ORIGINS=http://localhost:5173
